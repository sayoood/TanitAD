    "primary_half_width": 1.75,
    "grid": [
      1.0,
      1.75,
      2.5
    ],
    "citation": "1.75 m = half of a 3.5 m lane (US arterial / DE Autobahn class); 1.0 m ~ wheel-over-line for a ~1.8 m vehicle; 2.5 m ~ into the adjacent lane."
  },
