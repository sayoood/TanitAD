# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Experiment artifacts (records stay, heavy binaries don't)
stack/experiments/**/*.pt
stack/experiments/**/*.ckpt
*.onnx
*.engine

# Data (never commit datasets)
data/
# ...but tanitad/data is the source package (loaders/adapters), not a dataset dir.
# Re-include the dir + its .py only (keeps __pycache__ etc. ignored).
!stack/tanitad/data/
!stack/tanitad/data/*.py
*.parquet
*.h5
*.hdf5
*.mp4
*.avi

# Google Drive sync artifacts
*.gdoc
*.gsheet
desktop.ini
~$*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Secrets
.env
*.token
hf_token*
Keys.txt
keys.txt

# fleet_probe per-run step memory (local, not shared state)
tools/.fleet_probe_state.json
