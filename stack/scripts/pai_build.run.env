# =============================================================================
# Run manifest: PhysicalAI phase0 cache-build to full 3000 (2400 train + 600 val)
# =============================================================================
# Sourced by supervise_run.sh / pod_boot_hook.sh (deployed to
# /workspace/ops/runs.d/pai-build.env on pod2). Single-process, resumable
# (build_episodes_cached skips existing ep_/skip_), boot-persistent. Done token
# is PAI_CACHE_DONE (printed by build_pai_cache.py on completion).
#
# TRAIN_CMD stores the HF-token EXTRACTION command (single-quoted), so the token
# is read at run time and never written to disk or logged.
RUN_ID="pai-build-3000"
WORKDIR="/workspace/TanitAD/stack"
OUT="/workspace/ops/pai-build"
OPS_DIR="/workspace/ops"
DONE_TOKEN="PAI_CACHE_DONE"
HB_PERIOD="60"
INIT_BACKOFF="30"
ENABLED="1"
TRAIN_CMD='export HF_TOKEN=$(grep -oE "hf_[A-Za-z0-9]+" /workspace/TanitAD/Keys.txt | head -1); python -u scripts/build_pai_cache.py --root /workspace/data/physicalai_phase0'
