# =============================================================================
# Run manifest: FLAGSHIP 4-brain — Phase-0 raw cache, 30k steps (Axis-6)
# =============================================================================
# Sourced by supervise_run.sh and pod_boot_hook.sh. Copy this to
#   /workspace/ops/runs.d/flagship-phase0.env   on the pod that HOLDS the cache,
# then: bash scripts/pod_boot_hook.sh   (launches + auto-relaunches on reboot).
#
# IMPORTANT (verified 2026-07-13): the 1856-episode phase0 cache lives ONLY on
# the pod2 network volume (mfs ca-mtl-1, ws-inode 194126314). pod3 mounts a
# DIFFERENT volume and canNOT see it; pod1 is a different DC on local NVMe. So
# CACHE_DIR/OUT below are pod2-local. If the run is moved to another pod, the
# cache must first be copied there and these paths updated.
# -----------------------------------------------------------------------------
RUN_ID="flagship-phase0-30k"
WORKDIR="/workspace/TanitAD/stack"
OUT="/workspace/experiments/flagship4b-phase0-30k"     # persistent: ckpt.pt every 1000
CACHE_DIR="/workspace/data/physicalai_phase0/_epcache"  # *train* subdir has ep_*.pt
DONE_TOKEN="FLAGSHIP4B_DONE"
ENABLED="1"

# Exact trainer command (args verified against scripts/train_flagship4b.py @0f93b98):
#   --data cached            single-corpus phase0 raw cache (roots[:1])
#   --config flagship4b      FULL 4-brain, goal_h=20, sigreg free_dims=64 baked in
#   --sigreg-free-dims 64    explicit per Axis-6 (matches config default)
#   --batch-size 16 --accum 4 --grad-checkpoint   measured-safe A40 recipe (F-5)
#   --ckpt-every 1000        atomic ckpt.pt -> auto-resume point on relaunch
#   --episodes 0 (default)   use ALL complete episodes (1856), mmap-backed
TRAIN_CMD='PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True python -u scripts/train_flagship4b.py \
  --data cached --cache-dirs /workspace/data/physicalai_phase0/_epcache \
  --config flagship4b --sigreg-free-dims 64 \
  --steps 30000 --batch-size 16 --accum 4 --grad-checkpoint \
  --lr 3e-4 --warmup 2000 --ckpt-every 1000 --log-every 50 --workers 4 \
  --out /workspace/experiments/flagship4b-phase0-30k'
