{
  "encoder": {
    "in_channels": 1,
    "image_size": 64,
    "patch_size": 8,
    "d_model": 64,
    "depth": 2,
    "n_heads": 2
  },
  "predictor": {
    "d_model": 64,
    "depth": 2,
    "n_heads": 2,
    "window": 4,
    "horizons": [
      1,
      2
    ],
